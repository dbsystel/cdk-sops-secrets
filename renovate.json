{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["gomod", "npm", "mise", "github-actions"],

  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "enabled": true,
      "groupName": "go-deps",
      "automerge": true
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "go-deps",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm-deps",
      "automerge": true
    },
    {
      "matchManagers": ["mise"],
      "groupName": "mise-tools",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    }
  ],
  "postUpdateOptions": ["gomodTidy"],
  "pinDigests": true
}
